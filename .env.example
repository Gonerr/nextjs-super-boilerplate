APP_ENV=development
NEXT_PUBLIC_APP_ENV=development

# Optional: internal origin for server-side requests to own API (e.g. in Docker when public hostname is not resolvable).
# Example: APP_INTERNAL_ORIGIN=http://127.0.0.1:3000
APP_INTERNAL_ORIGIN=

# JWT
JWT_SECRET=
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=15724800

# MongoDB — 2 Variants:
# 1) External cluster: set MONGO_URI (full connection string, e.g. Atlas).
# 2) Local container (mongo_enabled: true in deploy): you can set MONGO_URI=mongodb://mongo:27017/app or set separate fields below.
MONGO_URI=
# If MONGO_URI is not set, the string is assembled from the fields below.
# Use mongo when app runs in Docker (same network as mongo container); use localhost for local dev on host.
MONGO_HOST=mongo
MONGO_PORT=27017
MONGO_USER=
MONGO_PASSWORD=
MONGO_DB=app
